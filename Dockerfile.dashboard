FROM python:3.12-slim

WORKDIR /app

# ── 装中文字体（matplotlib 画图需要）──
RUN apt-get update && apt-get install -y --no-install-recommends \
    fonts-wqy-microhei \
    && rm -rf /var/lib/apt/lists/*

# ── pip 依赖 ──
RUN pip install -i https://pypi.tuna.tsinghua.edu.cn/simple --no-cache-dir \
    pandas matplotlib gradio requests

# ── 源码 ──
COPY 16_analytics_dashboard.py .
COPY conversations.db .

# ── 声明端口 ──
EXPOSE 7860

CMD ["python3", "16_analytics_dashboard.py"]
